# ── Entorno ──────────────────────────────────────────
# .env.example SÍ se versiona (plantilla para el equipo)
.env*
!.env.example

# ── Dependencias ─────────────────────────────────────
node_modules/

# ── Build / compilación ──────────────────────────────
# frontend/dist  → bundle estático generado por Vite
# core/dist      → JS compilado por tsc (NestJS)
dist/
build/

# ── Caché y herramientas de build ────────────────────
.vite/
*.tsbuildinfo
.eslintcache
.stylelintcache
.prettiercache

# ── Testing ──────────────────────────────────────────
coverage/
.nyc_output/

# ── Logs ─────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Sistema operativo ────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editores e IDEs ──────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.code-workspace

# ── Misceláneos ──────────────────────────────────────
*.pid
*.pid.lock
.cache/
tmp/
temp/
